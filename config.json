{
  "source": ["tokens.json"],
  "platforms": {
    "css": {
      "transformGroup": "css",
      "buildPath": "build/css/",
      "files": [{
        "destination": "variables.css",
        "format": "css/variables"
      }]
    },
    "tailwind": {
      "transformGroup": "js",
      "buildPath": "build/js/",
      "files": [{
        "destination": "tailwind-tokens.js",
        "format": "javascript/module"
      }]
    }
  }
}
